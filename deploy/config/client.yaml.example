# sys-mcp-client 配置示例
# 放置路径：~/.config/sys-mcp/client.yaml 或 ./sys-mcp-client.yaml
# 重要：chmod 0600 此文件——其中包含认证令牌。

center:
  # url 是 sys-mcp-center MCP 端点的 HTTP 基础 URL。
  url: "http://center.example.com:8080"
  # token 是与 center 认证用的 Bearer Token。
  token: "your-client-token-here"

logging:
  level: "info"   # debug | info | warn | error
  format: "json"  # json | text
