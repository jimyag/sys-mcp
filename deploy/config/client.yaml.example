# sys-mcp-client configuration example
# Place at ~/.config/sys-mcp/client.yaml or ./sys-mcp-client.yaml
# IMPORTANT: chmod 0600 this file — it contains your auth token.

center:
  # url is the HTTP base URL of sys-mcp-center's MCP endpoint.
  url: "http://center.example.com:8080"
  # token is the bearer token used to authenticate with center.
  token: "your-client-token-here"

logging:
  level: "info"   # debug | info | warn | error
